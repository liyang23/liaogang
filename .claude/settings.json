{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "/Users/liyang129/data/liaogang/.claude/hooks/session-start"
            ]
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "spec-plan",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "/Users/liyang129/data/liaogang/.claude/hooks/spec-plan-guard"
            ]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "/Users/liyang129/data/liaogang/.claude/hooks/prd-prewrite-guard"
            ]
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "/Users/liyang129/data/liaogang/.claude/hooks/prd-readiness-guard"
            ]
          }
        ]
      }
    ]
  }
}
